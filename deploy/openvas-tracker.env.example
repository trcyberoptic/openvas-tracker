# /etc/openvas-tracker/env
OT_SERVER_HOST=0.0.0.0
OT_SERVER_PORT=8080
OT_DATABASE_DSN=otracker:CHANGEME@tcp(localhost:3306)/openvas-tracker?parseTime=true
OT_JWT_SECRET=CHANGEME-use-openssl-rand-hex-32
OT_JWT_EXPIREHOURS=24
OT_IMPORT_APIKEY=CHANGEME-use-openssl-rand-hex-32-min-32-chars

# GMP credentials used by /usr/local/bin/openvas-tracker-fetch-latest when
# GVM triggers GET /api/import/openvas. Must be a Greenbone user with read
# access to the scan tasks/reports you want imported.
OT_GMP_USER=admin
OT_GMP_PASSWORD=CHANGEME
